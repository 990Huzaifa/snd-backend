<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>You're invited</title>
  </head>
  <body style="margin:0; padding:0; background:#f5f7fb; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;">

    <table width="100%" cellpadding="0" cellspacing="0" style="background:#f5f7fb; padding:40px 0;">
      <tr>
        <td align="center">

          <!-- Card -->
          <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:12px; padding:32px; box-shadow:0 8px 24px rgba(0,0,0,0.06);">

            <!-- Logo -->
            <tr>
              <td align="center" style="padding-bottom:20px;">
                <img src="{{logoUrl}}" alt="Logo" style="height:42px;" />
              </td>
            </tr>

            <!-- Heading -->
            <tr>
              <td align="center">
                <h2 style="margin:0; font-size:24px; color:#111827;">
                  You're invited 🎉
                </h2>
              </td>
            </tr>

            <!-- Subtext -->
            <tr>
              <td align="center" style="padding-top:12px;">
                <p style="margin:0; font-size:16px; color:#4b5563;">
                  <strong>{{invitedByName}}</strong> invited you to join
                  <strong>{{tenantName}}</strong>
                </p>
              </td>
            </tr>

            <!-- Description -->
            <tr>
              <td align="center" style="padding-top:16px;">
                <p style="margin:0; font-size:14px; color:#6b7280;">
                  Set up your account to get started with your workspace.
                </p>
              </td>
            </tr>

            <!-- Button -->
            <tr>
              <td align="center" style="padding:28px 0;">
                <a href="{{setupUrl}}"
                   style="
                     display:inline-block;
                     background:linear-gradient(135deg, #2563eb, #4f46e5);
                     color:#ffffff;
                     text-decoration:none;
                     padding:12px 22px;
                     font-size:15px;
                     border-radius:8px;
                     font-weight:600;
                     box-shadow:0 4px 12px rgba(37,99,235,0.3);
                   ">
                  Set up your account →
                </a>
              </td>
            </tr>

            <!-- Divider -->
            <tr>
              <td>
                <hr style="border:none; border-top:1px solid #e5e7eb; margin:0;">
              </td>
            </tr>

            <!-- Fallback -->
            <tr>
              <td style="padding-top:20px;">
                <p style="font-size:12px; color:#6b7280; margin:0;">
                  If the button doesn’t work, copy and paste this link:
                </p>
                <p style="font-size:12px; color:#2563eb; word-break:break-all; margin-top:8px;">
                  {{setupUrl}}
                </p>
              </td>
            </tr>

            <!-- Footer -->
            <tr>
              <td style="padding-top:28px;" align="center">
                <p style="font-size:12px; color:#9ca3af; margin:0;">
                  © {{year}} SalesVince. All rights reserved.
                </p>
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>

  </body>
</html>