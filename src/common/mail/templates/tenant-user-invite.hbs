<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>You're invited</title>
  </head>
  <body style="font-family: Arial, sans-serif; color: #111; line-height: 1.5;">
    <div style="max-width: 640px; margin: 0 auto; padding: 24px;">
      <img src="{{logoUrl}}" alt="Logo" style="height: 40px; margin-bottom: 20px;" />
      <h2 style="margin: 0 0 12px;">You're invited to {{tenantName}}</h2>
      <p style="margin: 0 0 12px;">
        {{invitedByName}} invited you to join {{tenantName}}.
      </p>
      <p style="margin: 0 0 20px;">
        Click the button below to set your password and activate your account.
      </p>
      <a
        href="{{setupUrl}}"
        style="display: inline-block; background: #2563eb; color: #fff; text-decoration: none; padding: 10px 16px; border-radius: 6px;"
      >
        Set up account
      </a>
      <p style="margin: 20px 0 0; font-size: 12px; color: #666;">
        If the button does not work, copy this URL in your browser:
      </p>
      <p style="margin: 8px 0 0; font-size: 12px; color: #666; word-break: break-all;">
        {{setupUrl}}
      </p>
      <p style="margin-top: 28px; font-size: 12px; color: #666;">
        &copy; {{year}} SalesVince
      </p>
    </div>
  </body>
</html>
